          <div class="faq-answer">
            <p data-i18n="faq6_a">{t.faq6_a}</p>
          </div>
        </div>
        <div class="faq-item animate-on-scroll">
          <button class="faq-question" id="faq-q7">
            <span data-i18n="faq7_q">{t.faq7_q}</span>
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-answer">
            <p data-i18n="faq7_a">{t.faq7_a}</p>
          </div>
        </div>
