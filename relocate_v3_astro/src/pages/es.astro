              <li data-i18n="visa2_ben4">{t.visa2_ben4}</li>
              <li data-i18n="visa2_ben5">{t.visa2_ben5}</li>
            </ul>
          </div>
        </div>

        <div class="visa-card animate-on-scroll">
          <div class="visa-card-header">
            <p class="visa-for" data-i18n="visa3_for">{t.visa3_for}</p>
            <h3 data-i18n="visa3_name">{t.visa3_name}</h3>
          </div>
          <div class="visa-card-body">
            <p class="visa-section-title" data-i18n="visa_req_label">{t.visa_req_label}</p>
            <ul class="visa-list">
              <li data-i18n="visa3_req1">{t.visa3_req1}</li>
              <li data-i18n="visa3_req2">{t.visa3_req2}</li>
              <li data-i18n="visa3_req3">{t.visa3_req3}</li>
              <li data-i18n="visa3_req4">{t.visa3_req4}</li>
              <li data-i18n="visa3_req5">{t.visa3_req5}</li>
            </ul>
            <p class="visa-section-title" data-i18n="visa_ben_label">{t.visa_ben_label}</p>
            <ul class="visa-list">
              <li data-i18n="visa3_ben1">{t.visa3_ben1}</li>
              <li data-i18n="visa3_ben2">{t.visa3_ben2}</li>
              <li data-i18n="visa3_ben3">{t.visa3_ben3}</li>
              <li data-i18n="visa3_ben4">{t.visa3_ben4}</li>
              <li data-i18n="visa3_ben5">{t.visa3_ben5}</li>
            </ul>
          </div>
        </div>

        <div class="visa-card animate-on-scroll">
          <div class="visa-card-header">
            <p class="visa-for" data-i18n="visa4_for">{t.visa4_for}</p>
            <h3 data-i18n="visa4_name">{t.visa4_name}</h3>
          </div>
          <div class="visa-card-body">
            <p class="visa-section-title" data-i18n="visa_req_label">{t.visa_req_label}</p>
            <ul class="visa-list">
              <li data-i18n="visa4_req1">{t.visa4_req1}</li>
              <li data-i18n="visa4_req2">{t.visa4_req2}</li>
              <li data-i18n="visa4_req3">{t.visa4_req3}</li>
              <li data-i18n="visa4_req4">{t.visa4_req4}</li>
              <li data-i18n="visa4_req5">{t.visa4_req5}</li>
            </ul>
            <p class="visa-section-title" data-i18n="visa_ben_label">{t.visa_ben_label}</p>
            <ul class="visa-list">
              <li data-i18n="visa4_ben1">{t.visa4_ben1}</li>
