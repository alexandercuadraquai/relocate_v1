---
import Layout from '../layouts/Layout.astro';
import { translations } from '../i18n/translations';

const lang = 'es';
const t = translations[lang];
const waLink = `https://wa.me/50766743696?text=${t.wa_text}`;
const canonical = `https://relocatepa.com/es`;
---

<Layout title={t.meta_title} description={t.meta_description} lang={lang} canonical={canonical}>

  <nav class="navbar" id="navbar">
    <div class="container">
      <a href="/es#hero" class="nav-logo"><img src="/images/logo-transparent.png" alt="Relocate to Panama" class="nav-logo-img"></a>
      <div class="nav-links" id="navLinks">
        <a href="/es#why-panama" data-i18n="nav_why">{t.nav_why}</a>
        <a href="/es#corporations" data-i18n="nav_corp">{t.nav_corp}</a>
        <a href="/es#visa-programs" data-i18n="nav_visa">{t.nav_visa}</a>
        <a href="/es#services" data-i18n="nav_services">{t.nav_services}</a>
        <a href="/es#contact" class="nav-cta" data-i18n="nav_contact">{t.nav_contact}</a>
        <div class="lang-toggle">
          <a href="/" class="lang-btn">EN</a>
          <a href="/es" class="lang-btn active">ES</a>
        </div>
      </div>
      <button class="hamburger" id="hamburger" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <section class="hero" id="hero">
    <div class="hero-bg"></div>
    <div class="hero-content">
      <img src="/images/logo-transparent.png" alt="Mudarse a Panamá" class="hero-logo">
      <p class="hero-label" data-i18n="hero_label">{t.hero_label}</p>
      <h1>
        <span data-i18n="hero_title_1">{t.hero_title_1}</span>
        <span class="accent" data-i18n="hero_title_2">{t.hero_title_2}</span>
      </h1>
      <p class="hero-subtitle" data-i18n="hero_subtitle">{t.hero_subtitle}</p>
      <div class="hero-buttons">
        <a href="/es#visa-programs" class="btn btn-primary" data-i18n="hero_btn_visa">{t.hero_btn_visa}</a>
        <a href="/es#why-panama" class="btn btn-outline" data-i18n="hero_btn_why">{t.hero_btn_why}</a>
      </div>
      <p class="trust-phrase" data-i18n="trust_phrase">{t.trust_phrase}</p>
    </div>
  </section>

  <section class="why-panama" id="why-panama">
    <div class="container">
      <p class="section-label animate-on-scroll" data-i18n="why_label">{t.why_label}</p>
      <h2 class="section-title animate-on-scroll" data-i18n="why_title">{t.why_title}</h2>
      <p class="section-desc animate-on-scroll" data-i18n="why_desc">{t.why_desc}</p>
      <div class="features-grid">
        <div class="feature-card animate-on-scroll">
          <div class="feature-icon">☀️</div>
          <h3 data-i18n="why_climate_title">{t.why_climate_title}</h3>
          <p data-i18n="why_climate_desc">{t.why_climate_desc}</p>
        </div>
        <div class="feature-card animate-on-scroll">
          <div class="feature-icon">📈</div>
          <h3 data-i18n="why_economy_title">{t.why_economy_title}</h3>
          <p data-i18n="why_economy_desc">{t.why_economy_desc}</p>
        </div>
        <div class="feature-card animate-on-scroll">
          <div class="feature-icon">🌐</div>
          <h3 data-i18n="why_location_title">{t.why_location_title}</h3>
          <p data-i18n="why_location_desc">{t.why_location_desc}</p>
        </div>
        <div class="feature-card animate-on-scroll">
          <div class="feature-icon">🏙️</div>
          <h3 data-i18n="why_living_title">{t.why_living_title}</h3>
          <p data-i18n="why_living_desc">{t.why_living_desc}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Cómo Funciona -->
  <section class="how-it-works-section" id="how-it-works">
    <div class="container">
      <p class="section-label animate-on-scroll">{t.hiw_label}</p>
      <h2 class="section-title animate-on-scroll">{t.hiw_title}</h2>
      <p class="section-desc animate-on-scroll">{t.hiw_desc}</p>
      <div class="steps-grid">
        <div class="step-card animate-on-scroll">
          <div class="step-number">{t.hiw1_num}</div>
          <h3>{t.hiw1_title}</h3>
          <p>{t.hiw1_desc}</p>
        </div>
        <div class="step-arrow animate-on-scroll">→</div>
        <div class="step-card animate-on-scroll">
          <div class="step-number">{t.hiw2_num}</div>
          <h3>{t.hiw2_title}</h3>
          <p>{t.hiw2_desc}</p>
        </div>
        <div class="step-arrow animate-on-scroll">→</div>
        <div class="step-card animate-on-scroll">
          <div class="step-number">{t.hiw3_num}</div>
          <h3>{t.hiw3_title}</h3>
          <p>{t.hiw3_desc}</p>
        </div>
      </div>
      <a href="/es#contact" class="btn btn-primary animate-on-scroll">{t.hiw_cta}</a>
    </div>
  </section>

  <section class="corp-section" id="corporations">
    <div class="container">
      <h2 class="section-title animate-on-scroll" data-i18n="corp_title">{t.corp_title}</h2>
      <p class="section-label animate-on-scroll" data-i18n="corp_subtitle">{t.corp_subtitle}</p>
      <p class="section-desc animate-on-scroll" data-i18n="corp_desc">{t.corp_desc}</p>
      
      <div class="visa-grid">
        <div class="visa-card animate-on-scroll" style="grid-column: 1 / -1;">
          <div class="visa-card-header" style="background: var(--text-dark)">
            <h3 data-i18n="corp_ben_title">{t.corp_ben_title}</h3>
          </div>
          <div class="visa-card-body">
            <div class="features-grid" style="grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));">
              <div>
                <h4 data-i18n="corp_ben1_title" style="color: var(--emerald); margin-bottom: 8px;">{t.corp_ben1_title}</h4>
                <p data-i18n="corp_ben1_desc">{t.corp_ben1_desc}</p>
              </div>
              <div>
                <h4 data-i18n="corp_ben2_title" style="color: var(--emerald); margin-bottom: 8px;">{t.corp_ben2_title}</h4>
                <p data-i18n="corp_ben2_desc">{t.corp_ben2_desc}</p>
              </div>
              <div>
                <h4 data-i18n="corp_ben3_title" style="color: var(--emerald); margin-bottom: 8px;">{t.corp_ben3_title}</h4>
                <p data-i18n="corp_ben3_desc">{t.corp_ben3_desc}</p>
              </div>
              <div>
                <h4 data-i18n="corp_ben4_title" style="color: var(--emerald); margin-bottom: 8px;">{t.corp_ben4_title}</h4>
                <p data-i18n="corp_ben4_desc">{t.corp_ben4_desc}</p>
              </div>
              <div>
                <h4 data-i18n="corp_ben5_title" style="color: var(--emerald); margin-bottom: 8px;">{t.corp_ben5_title}</h4>
                <p data-i18n="corp_ben5_desc">{t.corp_ben5_desc}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="visa-programs" id="visa-programs">
    <div class="container">
      <h2 class="section-title animate-on-scroll" data-i18n="visa_title">{t.visa_title}</h2>
      <p class="section-desc animate-on-scroll" data-i18n="visa_desc">{t.visa_desc}</p>
      <div class="visa-grid">
        
        <div class="visa-card animate-on-scroll">
          <div class="visa-card-header">
            <p class="visa-for" data-i18n="visa1_for">{t.visa1_for}</p>
            <h3 data-i18n="visa1_name">{t.visa1_name}</h3>
          </div>
          <div class="visa-card-body">
            <p class="visa-section-title" data-i18n="visa_req_label">{t.visa_req_label}</p>
            <ul class="visa-list">
              <li data-i18n="visa1_req1">{t.visa1_req1}</li>
              <li data-i18n="visa1_req2">{t.visa1_req2}</li>
              <li data-i18n="visa1_req3">{t.visa1_req3}</li>
              <li data-i18n="visa1_req4">{t.visa1_req4}</li>
              <li data-i18n="visa1_req5">{t.visa1_req5}</li>
            </ul>
            <p class="visa-section-title" data-i18n="visa_ben_label">{t.visa_ben_label}</p>
            <ul class="visa-list">
              <li data-i18n="visa1_ben1">{t.visa1_ben1}</li>
              <li data-i18n="visa1_ben2">{t.visa1_ben2}</li>
              <li data-i18n="visa1_ben3">{t.visa1_ben3}</li>
              <li data-i18n="visa1_ben4">{t.visa1_ben4}</li>
              <li data-i18n="visa1_ben5">{t.visa1_ben5}</li>
            </ul>
          </div>
        </div>

        <div class="visa-card animate-on-scroll">
          <div class="visa-card-header">
            <p class="visa-for" data-i18n="visa2_for">{t.visa2_for}</p>
            <h3 data-i18n="visa2_name">{t.visa2_name}</h3>
          </div>
          <div class="visa-card-body">
            <p class="visa-section-title" data-i18n="visa_req_label">{t.visa_req_label}</p>
            <ul class="visa-list">
              <li data-i18n="visa2_req1">{t.visa2_req1}</li>
              <li data-i18n="visa2_req2">{t.visa2_req2}</li>
              <li data-i18n="visa2_req3">{t.visa2_req3}</li>
              <li data-i18n="visa2_req4">{t.visa2_req4}</li>
              <li data-i18n="visa2_req5">{t.visa2_req5}</li>
            </ul>
            <p class="visa-section-title" data-i18n="visa_ben_label">{t.visa_ben_label}</p>
            <ul class="visa-list">
              <li data-i18n="visa2_ben1">{t.visa2_ben1}</li>
              <li data-i18n="visa2_ben2">{t.visa2_ben2}</li>
