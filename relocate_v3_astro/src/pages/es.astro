              <li data-i18n="visa4_ben5">{t.visa4_ben5}</li>
            </ul>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="legal-section" id="legal">
    <div class="container">
      <div class="legal-grid">
        <div class="legal-content">
          <p class="section-label animate-on-scroll" data-i18n="legal_label">{t.legal_label}</p>
          <h2 class="section-title animate-on-scroll" data-i18n="legal_title">{t.legal_title}</h2>
          <p class="legal-intro animate-on-scroll" data-i18n="legal_intro">{t.legal_intro}</p>
          
          <div class="legal-item animate-on-scroll">
            <h4 data-i18n="legal1_title">{t.legal1_title}</h4>
            <p data-i18n="legal1_desc">{t.legal1_desc}</p>
          </div>
          <div class="legal-item animate-on-scroll">
            <h4 data-i18n="legal2_title">{t.legal2_title}</h4>
            <p data-i18n="legal2_desc">{t.legal2_desc}</p>
          </div>
          <div class="legal-item animate-on-scroll">
            <h4 data-i18n="legal3_title">{t.legal3_title}</h4>
            <p data-i18n="legal3_desc">{t.legal3_desc}</p>
          </div>
          <div class="legal-item animate-on-scroll">
            <h4 data-i18n="legal4_title">{t.legal4_title}</h4>
            <p data-i18n="legal4_desc">{t.legal4_desc}</p>
          </div>
        </div>
        <div class="legal-image animate-on-scroll">
          <img src="/images/casco_bandera_edificio.jpeg" alt="Vista del Casco Antiguo en la Ciudad de Panamá" loading="lazy">
        </div>
      </div>
      <div class="disclaimer animate-on-scroll">
        <h4 data-i18n="disclaimer_title">{t.disclaimer_title}</h4>
        <p data-i18n="disclaimer_text">{t.disclaimer_text}</p>
      </div>
    </div>
  </section>

  <section class="services-section" id="services">
    <div class="container">
      <p class="section-label animate-on-scroll" data-i18n="services_label">{t.services_label}</p>
      <h2 class="section-title animate-on-scroll" data-i18n="services_title">{t.services_title}</h2>
      <p class="section-desc animate-on-scroll" data-i18n="services_desc">{t.services_desc}</p>
      <div class="services-grid">
        
        <div class="service-card animate-on-scroll">
          <div class="card-icon">🛂</div>
          <h3 data-i18n="svc1_title">{t.svc1_title}</h3>
          <p data-i18n="svc1_desc">{t.svc1_desc}</p>
        </div>
        <div class="service-card animate-on-scroll">
          <div class="card-icon">🏢</div>
          <h3 data-i18n="svc2_title">{t.svc2_title}</h3>
          <p data-i18n="svc2_desc">{t.svc2_desc}</p>
        </div>
        <div class="service-card animate-on-scroll">
          <div class="card-icon">📋</div>
          <h3 data-i18n="svc3_title">{t.svc3_title}</h3>
          <p data-i18n="svc3_desc">{t.svc3_desc}</p>
        </div>
        <div class="service-card animate-on-scroll">
          <div class="card-icon">🏠</div>
          <h3 data-i18n="svc4_title">{t.svc4_title}</h3>
          <p data-i18n="svc4_desc">{t.svc4_desc}</p>
        </div>

      </div>

      <div class="re-closings animate-on-scroll" style="margin-top: 80px; background: var(--bg-cream); padding: 50px; border-radius: var(--border-radius);">
        <div class="container" style="padding: 0;">
          <h2 class="section-title" data-i18n="re_title" style="text-align: left; margin-bottom: 24px;">{t.re_title}</h2>
          <p data-i18n="re_desc">{t.re_desc}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonios -->
  <section class="testimonials-section" id="testimonials">
    <div class="container">
      <p class="section-label animate-on-scroll">{t.testimonials_label}</p>
      <h2 class="section-title animate-on-scroll">{t.testimonials_title}</h2>
      <p class="section-desc animate-on-scroll">{t.testimonials_desc}</p>
      <!-- TODO: Reemplazar con testimonios reales verificados de clientes -->
      <div class="testimonials-grid">
        <div class="testimonial-card animate-on-scroll">
          <div class="testimonial-stars">★★★★★</div>
          <p class="testimonial-text">{t.t1_text}</p>
          <div class="testimonial-author">
            <div class="author-avatar">RM</div>
            <div class="author-info">
              <span class="author-name">{t.t1_name}</span>
              <span class="author-origin">{t.t1_origin}</span>
              <span class="author-visa">{t.t1_visa}</span>
            </div>
          </div>
        </div>
        <div class="testimonial-card animate-on-scroll">
          <div class="testimonial-stars">★★★★★</div>
          <p class="testimonial-text">{t.t2_text}</p>
          <div class="testimonial-author">
            <div class="author-avatar">CD</div>
            <div class="author-info">
              <span class="author-name">{t.t2_name}</span>
              <span class="author-origin">{t.t2_origin}</span>
              <span class="author-visa">{t.t2_visa}</span>
            </div>
          </div>
        </div>
        <div class="testimonial-card animate-on-scroll">
          <div class="testimonial-stars">★★★★★</div>
          <p class="testimonial-text">{t.t3_text}</p>
          <div class="testimonial-author">
            <div class="author-avatar">SK</div>
            <div class="author-info">
              <span class="author-name">{t.t3_name}</span>
              <span class="author-origin">{t.t3_origin}</span>
              <span class="author-visa">{t.t3_visa}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="faq-section" id="faq">
    <div class="container">
      <p class="section-label animate-on-scroll" data-i18n="faq_label">{t.faq_label}</p>
      <h2 class="section-title animate-on-scroll" data-i18n="faq_title">{t.faq_title}</h2>
      <p class="section-desc animate-on-scroll" data-i18n="faq_desc">{t.faq_desc}</p>
      <div class="faq-list">
        
        <div class="faq-item animate-on-scroll">
          <button class="faq-question" id="faq-q1">
            <span data-i18n="faq1_q">{t.faq1_q}</span>
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-answer">
            <p data-i18n="faq1_a">{t.faq1_a}</p>
          </div>
        </div>
        <div class="faq-item animate-on-scroll">
          <button class="faq-question" id="faq-q2">
            <span data-i18n="faq2_q">{t.faq2_q}</span>
