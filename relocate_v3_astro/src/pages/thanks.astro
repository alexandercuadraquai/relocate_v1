---
import Layout from '../layouts/Layout.astro';
import { translations } from '../i18n/translations';

const t = translations['en'];
---

<Layout title="Thank You | Relocate to Panama" description="Thank you for your inquiry." lang="en">
  <nav class="navbar scrolled">
    <div class="container">
      <a href="/" class="nav-logo"><img src="/images/logo-transparent.png" alt="Relocate to Panama" class="nav-logo-img"></a>
      <div class="nav-links">
        <a href="/" class="nav-cta">Back to Home</a>
      </div>
    </div>
  </nav>

  <main style="min-height: 80vh; display: flex; align-items: center; justify-content: center; text-align: center; padding: 120px 24px;">
    <div class="container" style="max-width: 600px;">
      <div style="font-size: 5rem; margin-bottom: 24px;">📧</div>
      <h1 style="font-size: 3rem; margin-bottom: 24px; color: var(--text-dark);">Thank You!</h1>
      <p style="font-size: 1.25rem; color: var(--text-body); margin-bottom: 40px;">
        Your message has been successfully sent. Our legal team will get back to you shortly.
      </p>
      <a href="/" class="btn btn-primary">Return to Homepage</a>
    </div>
  </main>

  <footer class="footer">
    <div class="container" style="text-align: center;">
      <p>© 2026 RelocatePanama. All rights reserved.</p>
    </div>
  </footer>
</Layout>
