---
import Layout from '../layouts/Layout.astro';
import { translations, type Lang } from '../i18n/translations';

const lang: Lang = 'en';
const t = translations[lang];
const waLink = `https://wa.me/50766743696?text=${t.wa_text}`;

// Explicitly flattened arrays removed, we use explicit HTML to ensure client-side data-i18n works.
---

<Layout title="Relocate to Panama: Residency, Visas & Investment" description="Expert legal guidance on residency visas, banking, corporate formation, and settling in Panama." lang={lang}>

  <nav class="navbar" id="navbar">
    <div class="container">
      <a href="#hero" class="nav-logo"><img src="/images/logo.png" alt="Relocate to Panama" class="nav-logo-img"></a>
