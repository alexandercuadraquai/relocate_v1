        <a href="#why-panama" data-i18n="nav_why">{t.nav_why}</a>
        <a href="#visa-programs" data-i18n="nav_visa">{t.nav_visa}</a>
        <a href="#legal" data-i18n="nav_legal">{t.nav_legal}</a>
        <a href="#services" data-i18n="nav_services">{t.nav_services}</a>
        <a href="#contact" class="nav-cta" data-i18n="nav_contact">{t.nav_contact}</a>
        <div class="lang-toggle">
          <button class="lang-btn active" data-lang="en" id="langEN">EN</button>
          <button class="lang-btn" data-lang="es" id="langES">ES</button>
        </div>
      </div>
      <button class="hamburger" id="hamburger" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

