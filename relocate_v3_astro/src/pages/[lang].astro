          <a href={`${base}/#hero`} class="nav-logo"><img src="/images/logo-transparent.png" alt="Relocate to Panama" class="footer-logo-img"></a>
          <p data-i18n="footer_tagline">{t.footer_tagline}</p>
        </div>
