---
import Layout from '../layouts/Layout.astro';
import { translations, type Lang } from '../i18n/translations';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'es' } },
  ];
}

const { lang } = Astro.params as { lang: Lang };
const t = translations[lang];
const waLink = `https://wa.me/50766743696?text=${t.wa_text}`;
const otherLang = lang === 'en' ? 'es' : 'en';
const isEn = lang === 'en';
const base = isEn ? '' : `/${lang}`;
const canonical = isEn ? 'https://relocatepa.com' : `https://relocatepa.com/${lang}`;
---

<Layout title={t.meta_title} description={t.meta_description} lang={lang} canonical={canonical}>

  <nav class="navbar" id="navbar">
    <div class="container">
      <a href={`${base}/#hero`} class="nav-logo"><img src="/images/logo-transparent.png" alt="Relocate to Panama" class="nav-logo-img"></a>
      <div class="nav-links" id="navLinks">
        <a href={`${base}/#why-panama`} data-i18n="nav_why">{t.nav_why}</a>
        <a href={`${base}/#visa-programs`} data-i18n="nav_visa">{t.nav_visa}</a>
        <a href={`${base}/#legal`} data-i18n="nav_legal">{t.nav_legal}</a>
        <a href={`${base}/#services`} data-i18n="nav_services">{t.nav_services}</a>
        <a href={`${base}/#contact`} class="nav-cta" data-i18n="nav_contact">{t.nav_contact}</a>
        <div class="lang-toggle">
          <a href="/" class={`lang-btn ${lang === 'en' ? 'active' : ''}`} id="langEN">EN</a>
          <a href="/es" class={`lang-btn ${lang === 'es' ? 'active' : ''}`} id="langES">ES</a>
        </div>
      </div>
      <button class="hamburger" id="hamburger" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <section class="hero" id="hero">
    <div class="hero-bg"></div>
    <div class="hero-content">
      <img src="/images/logo-transparent.png" alt="Relocate to Panama" class="hero-logo">
      <p class="hero-label" data-i18n="hero_label">{t.hero_label}</p>
      <h1>
        <span data-i18n="hero_title_1">{t.hero_title_1}</span>
        <span class="accent" data-i18n="hero_title_2">{t.hero_title_2}</span>
      </h1>
      <p class="hero-subtitle" data-i18n="hero_subtitle">{t.hero_subtitle}</p>
      <div class="hero-buttons">
        <a href={`/${lang}#visa-programs`} class="btn btn-primary" data-i18n="hero_btn_visa">{t.hero_btn_visa}</a>
        <a href={`/${lang}#why-panama`} class="btn btn-outline" data-i18n="hero_btn_why">{t.hero_btn_why}</a>
      </div>
    </div>
  </section>

  <section class="why-panama" id="why-panama">
    <div class="container">
      <p class="section-label animate-on-scroll" data-i18n="why_label">{t.why_label}</p>
      <h2 class="section-title animate-on-scroll" data-i18n="why_title">{t.why_title}</h2>
      <p class="section-desc animate-on-scroll" data-i18n="why_desc">{t.why_desc}</p>
      <div class="features-grid">
        <div class="feature-card animate-on-scroll">
          <div class="feature-icon">☀️</div>
          <h3 data-i18n="why_climate_title">{t.why_climate_title}</h3>
          <p data-i18n="why_climate_desc">{t.why_climate_desc}</p>
        </div>
        <div class="feature-card animate-on-scroll">
          <div class="feature-icon">📈</div>
          <h3 data-i18n="why_economy_title">{t.why_economy_title}</h3>
          <p data-i18n="why_economy_desc">{t.why_economy_desc}</p>
        </div>
        <div class="feature-card animate-on-scroll">
          <div class="feature-icon">🌐</div>
          <h3 data-i18n="why_location_title">{t.why_location_title}</h3>
          <p data-i18n="why_location_desc">{t.why_location_desc}</p>
        </div>
        <div class="feature-card animate-on-scroll">
          <div class="feature-icon">🏙️</div>
          <h3 data-i18n="why_living_title">{t.why_living_title}</h3>
          <p data-i18n="why_living_desc">{t.why_living_desc}</p>
        </div>
      </div>
    </div>
  </section>

